#!/usr/bin/env bash
# codex-buddy: 启动 Codex CLI + buddy 伴侣（tmux 分屏）
# 用法: codex-buddy [codex 参数...]

BUDDY_HOME="$HOME/.codex/buddy"
SESSION="codex-buddy"

# 检查 tmux
command -v tmux >/dev/null 2>&1 || { echo "需要 tmux: brew install tmux"; exit 1; }
command -v node >/dev/null 2>&1 || { echo "需要 Node.js >= 18"; exit 1; }

# 如果已经在 tmux 里，直接用当前 session
if [ -n "$TMUX" ]; then
    # 右侧开 buddy 面板
    tmux split-window -h -l 20 "cd $BUDDY_HOME && node buddy-panel.js"
    # 左侧面板运行 codex
    codex "$@"
    # codex 退出后关掉 buddy 面板
    tmux kill-pane -t right 2>/dev/null
    exit 0
fi

# 不在 tmux 里，创建新 session
tmux kill-session -t "$SESSION" 2>/dev/null

# 构建 codex 命令（传递所有参数）
CODEX_CMD="codex $*; tmux kill-session -t $SESSION"

tmux new-session -d -s "$SESSION" -x "$(tput cols)" -y "$(tput lines)" "$CODEX_CMD"
tmux split-window -h -t "$SESSION" -l 20 "cd $BUDDY_HOME && node buddy-panel.js"
tmux select-pane -t "$SESSION:0.0"  # 焦点回到 codex
tmux attach -t "$SESSION"
